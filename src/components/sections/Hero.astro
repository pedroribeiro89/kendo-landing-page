---
// src/components/sections/Hero.astro
---
<section class="relative overflow-hidden pt-32 pb-24 sm:pt-40 sm:pb-32 md:pt-48 md:pb-40">
  <div aria-hidden="true" class="ghost-kanji text-[length:var(--text-kanji)] text-[var(--color-kendo-red)] -right-[5%] top-[15%]" lang="ja" data-kanji="剣"></div>

  <div class="container-page relative z-10 max-w-[1100px]">
    <p class="text-[length:var(--text-eyebrow)] tracking-[0.4em] uppercase font-bold text-[var(--color-iaido-gold)] mb-8">
      Belo Horizonte · Desde 2008
    </p>

    <h1 class="font-[family-name:var(--font-display)] font-extrabold tracking-[-0.025em] leading-[0.95] text-[length:var(--text-h1)] mb-6">
      Kendo e Iaido.<br />A arte da <span class="text-[var(--color-kendo-red)]">espada japonesa.</span>
    </h1>

    <p lang="ja" class="text-[var(--color-iaido-gold)] tracking-[0.4em] font-semibold uppercase text-sm mb-8">
      剣道 · 居合道
    </p>

    <p class="text-[length:var(--text-lede)] text-[var(--color-ink-300)] leading-relaxed max-w-[58ch] mb-10">
      Único grupo de kendo autêntico em Belo Horizonte, vinculado à CBK e à FIK Japão. <strong class="text-[var(--color-paper)] font-semibold">O mesmo kendo treinado no Japão e mundialmente.</strong>
    </p>

    <ul class="flex flex-wrap gap-x-10 gap-y-2 mb-10 text-xs uppercase tracking-[0.2em] text-[var(--color-ink-500)]">
      <li class="flex items-baseline gap-3">
        <strong class="text-[var(--color-paper)] font-bold">Kendo</strong>
      </li>
      <li class="flex items-baseline gap-3">
        <strong class="text-[var(--color-paper)] font-bold">Iaido</strong>
        <span>Seitei + Mugai-ryu</span>
      </li>
    </ul>

    <a href="#keiko" class="inline-flex items-center gap-2 rounded bg-[var(--color-kendo-red)] px-6 py-3 text-sm font-bold uppercase tracking-[0.18em] text-[var(--color-ink-900)] transition-transform hover:-translate-y-0.5">
      Marcar aula experimental
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8"/>
      </svg>
    </a>
  </div>
</section>
